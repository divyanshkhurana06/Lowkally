# Copy to .env and fill in values (never commit .env)

# --- Gemini / ADK ---
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- GitLab MCP (server-side token) ---
GITLAB_PERSONAL_ACCESS_TOKEN=
GITLAB_API_URL=https://gitlab.com/api/v4

# --- Public URL (required for production OAuth) ---
APP_URL=http://localhost:3000
JWT_SECRET=change-me-in-production

# --- OAuth login (separate from GOOGLE_API_KEY / Gemini) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
# Issue reports → GitHub Issues (maintainer inbox)
GITHUB_ISSUES_URL=https://github.com/divyanshkhurana06/Lowkally/issues
GITHUB_ISSUES_TOKEN=
# Optional shorthand instead of GITHUB_ISSUES_URL:
# GITHUB_ISSUES_REPO=divyanshkhurana06/Lowkally

# --- Agent ---
PORT=8080
CORS_ORIGINS=http://localhost:3000
FORGE_WORKSPACE=./forge/workspace
FORGE_DATA_DIR=./forge/data
FORGE_MAX_ITERATIONS=10
FORGE_CMD_TIMEOUT=120
FORGE_SERVER_PROBE=120

# --- Frontend (local dev) ---
API_URL=http://127.0.0.1:8080
NEXT_PUBLIC_API_URL=

# --- Hackathon / production tuning ---
# FORGE_ADK_TIMEOUT=60          # ADK phase before pipeline fallback (keep ADK visible for judges)
# LOWKALLY_PIPELINE_ONLY=1      # Skip ADK entirely (faster runs, not ideal for GitLab track demo)
